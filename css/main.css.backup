/* Import Font Awesome */
@import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css');

/* Custom CSS Variables */
:root {
  --primary: #6366f1;
  --primary-dark: #4f46e5;
  --secondary: #ec4899;
  --accent: #06b6d4;
}

/* Custom animations */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulseSlow {
  0%, 100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.6;
  }
}

.animate-fade-in-up {
  animation: fadeInUp 0.8s ease-out;
}

.animate-pulse-slow {
  animation: pulseSlow 4s ease-in-out infinite;
}

/* Custom utility classes */
.text-primary { color: var(--primary); }
.text-primary-dark { color: var(--primary-dark); }
.text-secondary { color: var(--secondary); }
.text-accent { color: var(--accent); }

.bg-primary { background-color: var(--primary); }
.bg-primary-dark { background-color: var(--primary-dark); }
.bg-secondary { background-color: var(--secondary); }
.bg-accent { background-color: var(--accent); }

.border-primary { border-color: var(--primary); }
.border-secondary { border-color: var(--secondary); }
.border-accent { border-color: var(--accent); }

/* Dark theme base */
body {
  background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
  color: #f9fafb;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
}

/* Enhanced prose styling */
.prose h1 { 
  color: #f9fafb; 
  font-weight: 800;
  font-size: 2.25rem;
  margin-bottom: 1.5rem;
  margin-top: 2rem;
}
.prose h2 { 
  color: var(--primary); 
  font-weight: 700;
  font-size: 1.875rem;
  margin-bottom: 1rem;
  margin-top: 2rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--primary);
}
.prose h3 { 
  color: var(--secondary); 
  font-weight: 600;
  font-size: 1.5rem;
  margin-bottom: 0.75rem;
  margin-top: 1.5rem;
}
.prose p { 
  color: #d1d5db; 
  line-height: 1.75;
  margin-bottom: 1.25rem;
}
.prose ul, .prose ol { 
  color: #d1d5db;
  margin-bottom: 1.25rem;
  padding-left: 1.25rem;
}
.prose ul {
  list-style-type: disc;
}
.prose ol {
  list-style-type: decimal;
}
.prose li { 
  margin-bottom: 0.5rem;
  color: #d1d5db;
}
.prose strong { 
  color: #f9fafb; 
  font-weight: 600;
}
.prose a {
  color: var(--primary);
  text-decoration: underline;
  text-decoration-color: var(--primary);
}
.prose a:hover {
  color: var(--primary-dark);
  text-decoration-color: var(--primary-dark);
}
.prose code {
  background: rgba(55, 65, 81, 0.5);
  color: var(--accent);
  padding: 0.25rem 0.5rem;
  border-radius: 0.375rem;
  font-size: 0.875rem;
}

/* iPhone landscape specific adjustments */
@media screen and (min-width: 640px) and (max-height: 450px) and (orientation: landscape) {
  /* Common adjustments for both demo and ecosystem sections */
  .demo-section h2,
  #ecosystem h2 {
    margin-bottom: 1rem;
  }
  
  .demo-section h3,
  #ecosystem h3 {
    margin-bottom: 0.5rem;
  }
  
  /* Code containers with scrolling */
  .demo-section pre,
  #ecosystem .bg-gray-800\/50 {
    max-height: 350px;
    overflow-y: auto;
  }
  
  /* Reduce minimum heights */
  .demo-section .min-h-\\[500px\\] {
    min-height: 350px !important;
  }
  
  /* Compact padding */
  #ecosystem .p-8 {
    padding: 1.5rem;
  }
  
  #ecosystem .mb-16 {
    margin-bottom: 2rem;
  }
}